{
  "main": ".open-next/worker.js",
  "name": "lorenzo-maiuri-website",
  "compatibility_date": "2025-03-25",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "vars": {
    // Non-sensitive. BACKEND_API_KEY is a Worker secret managed by Terraform (infra/secrets.tf).
    "BACKEND_API_URL": "https://lorenzobot-backend-806277161.europe-west3.run.app"
  }
}
